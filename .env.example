# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED: Get from Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql+pg8000://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (NO trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,https://your-dashboard-domain.com

# ── Workers ───────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=2
